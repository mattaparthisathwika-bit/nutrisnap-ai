# HuggingFace food vision (Aya Vision model via Inference Providers)
# 1. Create token: https://huggingface.co/settings/tokens
#    Enable: "Make calls to Inference Providers"
# 2. Enable Cohere provider: https://huggingface.co/settings/inference-providers
# 3. On web, also run: npm run proxy
EXPO_PUBLIC_HF_API_KEY=
EXPO_PUBLIC_HF_PROXY_URL=http://localhost:3001
EXPO_PUBLIC_HF_VISION_MODEL=CohereLabs/aya-vision-32b

# Alternatives (optional)
# EXPO_PUBLIC_GEMINI_API_KEY=
# EXPO_PUBLIC_OPENAI_API_KEY=
